{
  "name": "kyle-sandy-rsvp",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "description": "Kyle & Sandy 婚禮 RSVP (PWA)",
  "scripts": {
    "dev": "concurrently -k -n server,client -c blue,magenta \"npm:server\" \"npm:client\"",
    "client": "vite",
    "server": "node --env-file-if-exists=.env --watch server/index.js",
    "build": "vite build",
    "start": "node --env-file-if-exists=.env server/index.js",
    "preview": "vite preview"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "hono": "^4.6.14"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "concurrently": "^9.1.2",
    "svelte": "^5.19.0",
    "vite": "^6.0.7",
    "vite-plugin-pwa": "^1.3.0"
  }
}
