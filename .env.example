# 複製成 .env 後填入。Docker 部署時用環境變數帶入即可。

# 開發時的後端埠號（與前端 Vite 的 PORT 分開，避免搶埠）
API_PORT=8787
# 正式環境（Docker）後端會改用 PORT（容器對外埠）並同時服務前端

# SQLite 檔案路徑（Docker 內會掛載到 NAS 目錄，方便備份）
DB_PATH=./data/rsvp.db

# 管理後台密碼（/admin 登入用）。正式環境務必設定一個強密碼；開發環境預設 'dev'。
ADMIN_PASSWORD=

# ─── LINE 通知 ───────────────────────────────────────────────
# ⚠️ LINE Notify 已於 2025-03-31 停用，改用 LINE 官方帳號的 Messaging API。
# 設定步驟：
#   1. 到 https://manager.line.biz 建立一個免費「LINE 官方帳號」
#   2. 到 https://developers.line.biz 為它建立一個 Messaging API channel
#   3. 在 channel 設定頁取得「Channel access token (long-lived)」貼到下方
#   4. 用你的手機 LINE 把這個官方帳號「加好友」
# 不填則不發送通知（不影響表單送出）。
LINE_CHANNEL_ACCESS_TOKEN=

# 通知對象 userId（必填才會發送；可逗號分隔多人）。留空則不發送（不使用 broadcast）。
LINE_TO=
