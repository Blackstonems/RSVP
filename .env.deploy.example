# 部署用環境變數範本
# 在 NAS 上把這個檔複製成「.env」，放在 docker-compose.yml 同一層，填入下列值。

# 後台 /admin 登入密碼（務必改成強密碼）
ADMIN_PASSWORD=change-me-請改成你的密碼

# LINE Messaging API long-lived token（沒有可先留空，之後再填並重啟容器即可）
LINE_CHANNEL_ACCESS_TOKEN=

# 通知對象的 LINE userId（必填才會發送，可逗號分隔多人，例如新郎、新娘都收到）
# ⚠️ 留空就不發送；本系統刻意不使用 broadcast，避免誤發給官方帳號的所有好友
LINE_TO=

# app 對外的主機埠；你現成的 Cloudflare Tunnel 把 rsvp.blst.cc 指到 http://localhost:這個埠
# 預設 8080；若 NAS 上已被占用，改別的（並讓 tunnel 的 Service URL 用同一個埠）
APP_PORT=8080

# 只有「沒有現成 tunnel、改用 docker-compose 內建 cloudflared」時才需要：
# TUNNEL_TOKEN=
